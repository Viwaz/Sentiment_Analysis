# =============================================================
# Sentiment Analysis – Environment Variables
# Copy this file to .env and fill in your own values.
# DO NOT commit .env to version control.
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentiment_db
DB_USER=sentiment_user
DB_PASSWORD=changeme

# ── JWT Auth ──────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Groq LLM Insight Engine ───────────────────────────────────
# Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ── Streamlit → FastAPI bridge ────────────────────────────────
# URL where the FastAPI backend (src/model_api.py) is running.
# Change the port if you start uvicorn on a different port.
BACKEND_URL=http://localhost:8000